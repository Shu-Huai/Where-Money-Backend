<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--
转账账单映射器
用于处理转账账单相关的数据库操作
-->
<mapper namespace="shuhuai.wheremoney.mapper.TransferBillMapper">
    <!--
    转账账单结果映射
    将数据库查询结果映射到TransferBill实体类
    -->
    <resultMap id="TransferBillResultMap" type="shuhuai.wheremoney.entity.TransferBill">
        <id column="id" jdbcType="INTEGER" javaType="Integer" property="id"/>
        <result column="book_id" jdbcType="INTEGER" javaType="Integer" property="bookId"/>
        <result column="in_asset_id" jdbcType="INTEGER" javaType="Integer" property="inAssetId"/>
        <result column="out_asset_id" jdbcType="INTEGER" javaType="Integer" property="outAssetId"/>
        <result column="amount" jdbcType="DECIMAL" javaType="BigDecimal" property="amount"/>
        <result column="transfer_fee" jdbcType="DECIMAL" javaType="BigDecimal" property="transferFee"/>
        <result column="bill_time" jdbcType="TIMESTAMP" javaType="java.sql.Timestamp" property="billTime"/>
        <result column="remark" jdbcType="VARCHAR" javaType="String" property="remark"/>
        <result column="image" property="image" typeHandler="org.apache.ibatis.type.BlobTypeHandler"/>
        <result column="image_content_type" jdbcType="VARCHAR" javaType="String" property="imageContentType"/>
    </resultMap>
    
    <!--
    选择性插入转账账单
    根据传入的TransferBill对象属性，选择性地插入数据
    使用生成的主键值
    -->
    <insert id="insertTransferBillSelective" useGeneratedKeys="true" keyProperty="id"
            parameterType="shuhuai.wheremoney.entity.TransferBill">
        insert into transfer_bill
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="bookId != null">
                book_id,
            </if>
            <if test="inAssetId != null">
                in_asset_id,
            </if>
            <if test="outAssetId != null">
                out_asset_id,
            </if>
            <if test="amount != null">
                amount,
            </if>
            <if test="transferFee != null">
                transfer_fee,
            </if>
            <if test="billTime != null">
                bill_time,
            </if>
            <if test="remark != null">
                remark,
            </if>
            <if test="image != null">
                image,
            </if>
            <if test="imageContentType != null">
                image_content_type,
            </if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="bookId != null">
                #{bookId,jdbcType=INTEGER},
            </if>
            <if test="inAssetId != null">
                #{inAssetId,jdbcType=INTEGER},
            </if>
            <if test="outAssetId != null">
                #{outAssetId,jdbcType=INTEGER},
            </if>
            <if test="amount != null">
                #{amount,jdbcType=DECIMAL},
            </if>
            <if test="transferFee != null">
                #{transferFee,jdbcType=DECIMAL},
            </if>
            <if test="billTime != null">
                #{billTime,jdbcType=TIMESTAMP},
            </if>
            <if test="remark != null">
                #{remark,jdbcType=VARCHAR},
            </if>
            <if test="image != null">
                #{image,jdbcType=BLOB},
            </if>
            <if test="imageContentType != null">
                #{imageContentType,jdbcType=VARCHAR},
            </if>
        </trim>
    </insert>
    
    <!--
    根据ID删除转账账单
    删除指定ID的转账账单
    -->
    <delete id="deleteTransferBillById" parameterType="Integer">
        delete
        from transfer_bill
        where id = #{id,jdbcType=INTEGER}
    </delete>
    
    <!--
    选择性更新转账账单
    根据传入的TransferBill对象属性，选择性地更新数据
    -->
    <update id="updateTransferBillByIdSelective" parameterType="shuhuai.wheremoney.entity.TransferBill">
        update transfer_bill
        <set>
            <if test="bookId != null">
                book_id = #{bookId,jdbcType=INTEGER},
            </if>
            <if test="inAssetId != null">
                in_asset_id = #{inAssetId,jdbcType=INTEGER},
            </if>
            <if test="outAssetId != null">
                out_asset_id = #{outAssetId,jdbcType=INTEGER},
            </if>
            <if test="amount != null">
                amount = #{amount,jdbcType=DECIMAL},
            </if>
            <if test="transferFee != null">
                transfer_fee = #{transferFee,jdbcType=DECIMAL},
            </if>
            <if test="billTime != null">
                bill_time = #{billTime,jdbcType=DATE},
            </if>
            <if test="remark != null">
                remark = #{remark,jdbcType=VARCHAR},
            </if>
            <if test="image != null">
                image = #{image,jdbcType=BLOB},
            </if>
            <if test="imageContentType != null">
                image_content_type = #{imageContentType,jdbcType=VARCHAR},
            </if>
        </set>
        where id = #{id,jdbcType=INTEGER}
    </update>
    
    <!--
    更新转账账单
    全量更新转账账单数据
    -->
    <update id="updateTransferBillById" parameterType="shuhuai.wheremoney.entity.TransferBill">
        update transfer_bill
        <set>
            book_id = #{bookId,jdbcType=INTEGER},
            in_asset_id = #{inAssetId,jdbcType=INTEGER},
            out_asset_id = #{outAssetId,jdbcType=INTEGER},
            amount = #{amount,jdbcType=DECIMAL},
            transfer_fee = #{transferFee,jdbcType=DECIMAL},
            bill_time = #{billTime,jdbcType=DATE},
            remark = #{remark,jdbcType=VARCHAR},
            image = #{image,jdbcType=BLOB},
            image_content_type = #{imageContentType,jdbcType=VARCHAR},
        </set>
        where id = #{id,jdbcType=INTEGER}
    </update>
    
    <!--
    根据账本ID查询转账账单
    查询指定账本的所有转账账单，按时间倒序排序
    -->
    <select id="selectTransferBillByBookId" resultMap="TransferBillResultMap">
        select *
        from transfer_bill
        where book_id = #{bookId,jdbcType=INTEGER}
        order by bill_time desc
    </select>
    
    <!--
    根据账本ID和时间范围查询转账账单
    查询指定账本在指定时间范围内的所有转账账单，按时间倒序排序
    -->
    <select id="selectTransferBillByBookIdTime" resultMap="TransferBillResultMap">
        select *
        from transfer_bill
        where book_id = #{bookId,jdbcType=INTEGER}
          and bill_time &gt;= #{startTime,jdbcType=TIMESTAMP}
          and bill_time &lt; #{endTime,jdbcType=TIMESTAMP}
        order by bill_time desc
    </select>
    
    <!--
    根据ID查询转账账单
    查询指定ID的转账账单详情
    -->
    <select id="selectTransferBillById" resultMap="TransferBillResultMap">
        select *
        from transfer_bill
        where id = #{id,jdbcType=INTEGER}
    </select>
    
    <!--
    根据账本ID删除转账账单
    删除指定账本的所有转账账单
    -->
    <delete id="deleteTransferBillByBookId" parameterType="Integer">
        delete
        from transfer_bill
        where book_id = #{bookId,jdbcType=INTEGER}
    </delete>
</mapper>